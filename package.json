{
  "name": "@prsm/devtools",
  "version": "1.1.0",
  "description": "Read-only Express middleware dashboard for observing @prsm infrastructure at runtime",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "dist/client"
  ],
  "scripts": {
    "build:client": "cd client && npm run build",
    "prepublishOnly": "npm run build:client"
  },
  "keywords": [
    "devtools",
    "dashboard",
    "queue",
    "cron",
    "rate-limit",
    "realtime",
    "websocket",
    "observability"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@prsm/cells": "^1.2.0",
    "@prsm/cron": "^1.1.0",
    "@prsm/limit": "^1.1.1",
    "@prsm/lock": "^1.1.0",
    "@prsm/queue": "^3.0.8",
    "@prsm/workflow": "^3.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "engines": {
    "node": ">=18"
  }
}
